# For Kafka container
KAFKA_PLAINTEXT_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_NW1_PORT=9094
KAFKA_HOST_EXTERNAL_CONN=127.0.0.1
KAFKA_PORT_EXTERNAL=9092
KAFKA_UI_PORT_EXTERNAL=19092

# Garage - Object Storage
GARAGE_S3_API_EXPORT=3900
GARAGE_RPC_EXPORT=3901
GARAGE_ADMIN_EXPORT=3903
GARAGE_UI_EXPORT=3909

# Postgres UI - pgAdmin
PGADMIN_PORT_EXTERNAL=15432
PGADMIN_DEFAULT_EMAIL=lytranvinh.work@gmai.com
PGADMIN_DEFAULT_PASSWORD=YOUR_PASSWORD_HERE

# ScyllaDB
SCYLLADB_DEVELOPER_MODE=1
SCYLLADB_OVERPROVISIONED=1
SCYLLADB_SMP=1
SCYLLADB_MEMORY=1G
SCYLLADB_LISTEN_ADDRESS=0.0.0.0
SCYLLADB_RPC_ADDRESS=0.0.0.0
SCYLLADB_BROADCAST_ADDRESS=127.0.0.1
SCYLLADB_BROADCAST_RPC_ADDRESS=127.0.0.1
SCYLLADB_SEEDS=127.0.0.1
SCYLLADB_TRANSPORT_PORT_EXTERNAL=7000
SCYLLADB_CQL_PORT_EXTERNAL=9042
SCYLLADB_USER=cassandra
SCYLLADB_PASSWORD=YOUR_PASSWORD_HERE

# For Redis
REDIS_EXPORT=6379
REDIS_PASSWORD=YOUR_PASSWORD_HERE
REDIS_UI_PORT_EXTERNAL=16379

# For Postgres
POSTGRES_EXPORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE
POSTGRES_DB=main_db

# For Observability
JAEGER_UI_EXPORT=16686
JAEGER_OTLP_HTTP_EXPORT=4318
JAEGER_OTLP_GRPC_EXPORT=4317
PROMETHEUS_EXPORT=9090
GRAFANA_EXPORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=YOUR_PASSWORD_HERE

